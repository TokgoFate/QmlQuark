# This is a clang-format configuration file for C++ code style
# It controls formatting rules such as indentation, brace wrapping, spacing, and more
# For detailed documentation, see: https://clang.llvm.org/docs/ClangFormatStyleOptions.html
---
Language:        Cpp                # 语言类型，设置为C++
AccessModifierOffset: -4            # 访问修饰符缩进偏移量
AlignAfterOpenBracket: Align        # 括号后对齐方式
AlignArrayOfStructures: None        # 数组结构体对齐方式
AlignConsecutiveAssignments:
  Enabled:         true             # 是否对齐连续赋值语句
  AcrossEmptyLines: false            # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCompound:   false            # 是否对齐复合赋值
  AlignFunctionPointers: true       # 是否对齐函数指针赋值
  PadOperators:    true             # 是否填充操作符两边空格
AlignConsecutiveBitFields:
  Enabled:         true             # 是否对齐连续位域
  AcrossEmptyLines: false           # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCompound:   false            # 是否对齐复合位域
  AlignFunctionPointers: false      # 是否对齐函数指针位域
  PadOperators:    true            # 是否填充操作符两边空格
AlignConsecutiveDeclarations:
  Enabled:         true             # 是否对齐连续声明
  AcrossEmptyLines: false           # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCompound:   false            # 是否对齐复合声明
  AlignFunctionPointers: false      # 是否对齐函数指针声明
  PadOperators:    true            # 是否填充操作符两边空格
AlignConsecutiveMacros:
  Enabled:         true            # 是否对齐连续宏定义
  AcrossEmptyLines: false           # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCompound:   false            # 是否对齐复合宏
  AlignFunctionPointers: false      # 是否对齐函数指针宏
  PadOperators:    true            # 是否填充操作符两边空格
AlignConsecutiveShortCaseStatements:
  Enabled:         true            # 是否对齐短case语句
  AcrossEmptyLines: false           # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCaseArrows: false            # 是否对齐case箭头
  AlignCaseColons: true            # 是否对齐case冒号
AlignConsecutiveTableGenBreakingDAGArgColons:
  Enabled:         false            # TableGen相关，是否对齐DAG参数冒号
  AcrossEmptyLines: false           # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCompound:   false            # 是否对齐复合DAG参数
  AlignFunctionPointers: false      # 是否对齐函数指针DAG参数
  PadOperators:    false            # 是否填充操作符两边空格
AlignConsecutiveTableGenCondOperatorColons:
  Enabled:         false            # TableGen相关，是否对齐条件操作符冒号
  AcrossEmptyLines: false           # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCompound:   false            # 是否对齐复合条件操作符
  AlignFunctionPointers: false      # 是否对齐函数指针条件操作符
  PadOperators:    false            # 是否填充操作符两边空格
AlignConsecutiveTableGenDefinitionColons:
  Enabled:         false            # TableGen相关，是否对齐定义冒号
  AcrossEmptyLines: false           # 是否跨空行对齐
  AcrossComments:  false            # 是否跨注释对齐
  AlignCompound:   false            # 是否对齐复合定义
  AlignFunctionPointers: false      # 是否对齐函数指针定义
  PadOperators:    false            # 是否填充操作符两边空格
AlignEscapedNewlines: Left          # 转义换行符对齐方式
AlignOperands:   Align              # 操作数对齐方式
AlignTrailingComments:
  Kind:            Always           # 尾部注释对齐方式
  OverEmptyLines:  0                # 跨空行尾部注释对齐数
AllowAllArgumentsOnNextLine: true   # 允许所有参数在下一行
AllowAllParametersOfDeclarationOnNextLine: true # 允许所有声明参数在下一行
AllowBreakBeforeNoexceptSpecifier: Never # noexcept前是否允许换行
AllowShortBlocksOnASingleLine: Never # 是否允许短代码块单行显示
AllowShortCaseExpressionOnASingleLine: false # 是否允许短case表达式单行显示
AllowShortCaseLabelsOnASingleLine: false # 是否允许短case标签单行显示
AllowShortCompoundRequirementOnASingleLine: false # 是否允许短复合需求单行显示
AllowShortEnumsOnASingleLine: false # 是否允许短枚举单行显示
AllowShortFunctionsOnASingleLine: None # 是否允许短函数单行显示
AllowShortIfStatementsOnASingleLine: WithoutElse # 是否允许短if语句单行显示
AllowShortLambdasOnASingleLine: None # 是否允许短lambda单行显示
AllowShortLoopsOnASingleLine: false # 是否允许短循环单行显示
AlwaysBreakAfterDefinitionReturnType: None # 定义返回类型后是否总是换行
AlwaysBreakBeforeMultilineStrings: true # 多行字符串前是否总是换行
AttributeMacros:
  - __capability                    # 属性宏列表
BinPackArguments: true              # 是否紧凑排列参数
BinPackParameters: true             # 是否紧凑排列参数
BitFieldColonSpacing: Both          # 位域冒号间距
BreakBeforeBraces: Custom           # 大括号前换行方式
BraceWrapping:
  AfterCaseLabel:  false            # case标签后是否换行
  AfterClass:      true             # 类后是否换行
  AfterControlStatement: Always      # 控制语句后是否换行: Always\Never\MultiLineOnly\NeverForMacros
  AfterEnum:       false            # 枚举后是否换行
  AfterExternBlock: false           # extern块后是否换行
  AfterFunction:   true             # 函数后是否换行
  AfterNamespace:  true             # 命名空间后是否换行
  AfterObjCDeclaration: false       # ObjC声明后是否换行
  AfterStruct:     true             # 结构体后是否换行
  AfterUnion:      true             # 联合体后是否换行
  BeforeCatch:     false            # catch前是否换行
  BeforeElse:      true             # else前是否换行
  BeforeLambdaBody: false           # lambda体前是否换行
  BeforeWhile:     false            # while前是否换行
  IndentBraces:    false            # 是否缩进大括号
  SplitEmptyFunction: false         # 空函数是否分行
  SplitEmptyRecord: true            # 空记录是否分行
  SplitEmptyNamespace: true         # 空命名空间是否分行

BreakAdjacentStringLiterals: true   # 相邻字符串字面量是否换行
BreakAfterAttributes: Leave         # 属性后是否换行
BreakAfterJavaFieldAnnotations: false # Java字段注解后是否换行
BreakAfterReturnType: None          # 返回类型后是否换行
BreakArrays:     true               # 数组是否换行
BreakBeforeBinaryOperators: None    # 二元操作符前是否换行
BreakBeforeConceptDeclarations: Always # 概念声明前是否换行
BreakBeforeInlineASMColon: OnlyMultiline # 内联ASM冒号前是否换行
BreakBeforeTernaryOperators: true   # 三元操作符前是否换行
BreakConstructorInitializers: BeforeColon # 构造函数初始化器冒号前是否换行
BreakFunctionDefinitionParameters: false # 函数定义参数是否换行
BreakInheritanceList: BeforeColon   # 继承列表冒号前是否换行
BreakStringLiterals: true           # 字符串字面量是否换行
BreakTemplateDeclarations: Yes      # 模板声明是否换行
ColumnLimit:     90                 # 每行最大字符数
CommentPragmas:  '^ IWYU pragma:'   # 注释Pragma匹配
CompactNamespaces: false            # 是否紧凑命名空间
ConstructorInitializerIndentWidth: 4  # 构造函数初始化器缩进宽度
ContinuationIndentWidth: 4          # 换行缩进宽度
Cpp11BracedListStyle: true          # C++11大括号列表风格
DerivePointerAlignment: true        # 自动推断指针对齐方式
DisableFormat:   false              # 是否禁用格式化
EmptyLineAfterAccessModifier: Never # 访问修饰符后空行
EmptyLineBeforeAccessModifier: LogicalBlock # 访问修饰符前空行
ExperimentalAutoDetectBinPacking: false # 自动检测参数紧凑排列
FixNamespaceComments: true          # 修正命名空间注释
ForEachMacros:
  - foreach                         # foreach宏
  - Q_FOREACH                       # Qt foreach宏
  - BOOST_FOREACH                   # Boost foreach宏
IfMacros:
  - KJ_IF_MAYBE                     # if宏
IncludeBlocks:   Regroup            # include块分组方式
IncludeCategories:
  - Regex:           '^<ext/.*\.h>' # include分类，ext头文件
    Priority:        2
    SortPriority:    0
    CaseSensitive:   false
  - Regex:           '^<.*\.h>'     # include分类，普通头文件
    Priority:        1
    SortPriority:    0
    CaseSensitive:   false
  - Regex:           '^<.*'         # include分类，其他头文件
    Priority:        2
    SortPriority:    0
    CaseSensitive:   false
  - Regex:           '.*'           # include分类，所有文件
    Priority:        3
    SortPriority:    0
    CaseSensitive:   false
IncludeIsMainRegex: '([-_](test|unittest))?$' # 主include正则
IncludeIsMainSourceRegex: ''                  # 主源文件include正则
IndentAccessModifiers: false                  # 访问修饰符是否缩进
IndentCaseBlocks: false                       # case块是否缩进
IndentCaseLabels: true                        # case标签是否缩进
IndentExternBlock: AfterExternBlock           # extern块缩进方式
IndentGotoLabels: true                        # goto标签是否缩进
IndentPPDirectives: None                      # 预处理指令缩进方式
IndentRequiresClause: true                    # requires子句是否缩进
IndentWidth:     4                            # 基本缩进宽度
IndentWrappedFunctionNames: true             # 换行函数名是否缩进
InsertBraces:    true                        # 是否自动插入大括号
InsertNewlineAtEOF: true                     # 文件末尾是否插入新行
InsertTrailingCommas: None                    # 是否插入尾随逗号
IntegerLiteralSeparator:
  Binary:          0                          # 二进制字面量分隔符
  BinaryMinDigits: 0                          # 二进制字面量最小位数
  Decimal:         0                          # 十进制字面量分隔符
  DecimalMinDigits: 0                         # 十进制字面量最小位数
  Hex:             0                          # 十六进制字面量分隔符
  HexMinDigits:    0                          # 十六进制字面量最小位数
JavaScriptQuotes: Leave                       # JavaScript引号风格
JavaScriptWrapImports: true                   # JS导入语句换行
KeepEmptyLines:
  AtEndOfFile:     true                       # 文件末尾保留空行
  AtStartOfBlock:  false                      # 代码块开头保留空行
  AtStartOfFile:   true                       # 文件开头保留空行
LambdaBodyIndentation: Signature              # lambda体缩进方式
LineEnding:      DeriveLF                     # 行尾格式
MacroBlockBegin: ''                           # 宏块开始标记
MacroBlockEnd:   ''                           # 宏块结束标记
MainIncludeChar: Quote                        # 主include字符
MaxEmptyLinesToKeep: 1                        # 最大保留空行数
NamespaceIndentation: All                   # 命名空间缩进方式：仅嵌套命名空间内的代码缩进
ObjCBinPackProtocolList: Never                # ObjC协议列表紧凑排列
ObjCBlockIndentWidth: 4                       # ObjC块缩进宽度
ObjCBreakBeforeNestedBlockParam: true         # ObjC嵌套块参数前换行
ObjCSpaceAfterProperty: false                 # ObjC属性后空格
ObjCSpaceBeforeProtocolList: true             # ObjC协议列表前空格
PackConstructorInitializers: NextLine         # 构造函数初始化器紧凑排列
PenaltyBreakAssignment: 2                     # 赋值换行惩罚值
PenaltyBreakBeforeFirstCallParameter: 1       # 首参数换行惩罚值
PenaltyBreakComment: 300                      # 注释换行惩罚值
PenaltyBreakFirstLessLess: 120                # <<换行惩罚值
PenaltyBreakOpenParenthesis: 0                # 开括号换行惩罚值
PenaltyBreakScopeResolution: 500              # 作用域解析换行惩罚值
PenaltyBreakString: 1000                      # 字符串换行惩罚值
PenaltyExcessCharacter: 1000000               # 超字符数惩罚值
PenaltyIndentedWhitespace: 0                  # 缩进空白惩罚值
PenaltyReturnTypeOnItsOwnLine: 200            # 返回类型独行惩罚值
PointerAlignment: Left                        # 指针对齐方式
PPIndentWidth:   -1                           # 预处理指令缩进宽度
QualifierAlignment: Leave                     # 限定符对齐方式
RawStringFormats:
  - Language:        Cpp                      # 原始字符串格式，C++
    Delimiters:
      - cc
      - CC
      - cpp
      - Cpp
      - CPP
      - 'c++'
      - 'C++'
    CanonicalDelimiter: ''
    BasedOnStyle:    google
  - Language:        TextProto                # 原始字符串格式，TextProto
    Delimiters:
      - pb
      - PB
      - proto
      - PROTO
    EnclosingFunctions:
      - EqualsProto
      - EquivToProto
      - PARSE_PARTIAL_TEXT_PROTO
      - PARSE_TEST_PROTO
      - PARSE_TEXT_PROTO
      - ParseTextOrDie
      - ParseTextProtoOrDie
      - ParseTestProto
      - ParsePartialTestProto
    CanonicalDelimiter: pb
    BasedOnStyle:    google
ReferenceAlignment: Pointer                   # 引用对齐方式
ReflowComments:  true                         # 是否自动换行注释
RemoveBracesLLVM: false                       # 是否移除LLVM风格大括号
RemoveParentheses: Leave                      # 是否移除括号
RemoveSemicolon: false                        # 是否移除分号
RequiresClausePosition: OwnLine               # requires子句位置
RequiresExpressionIndentation: OuterScope     # requires表达式缩进方式
SeparateDefinitionBlocks: Leave               # 定义块分离方式
ShortNamespaceLines: 1                        # 短命名空间行数
SkipMacroDefinitionBody: false                # 跳过宏定义体
SortIncludes:    CaseSensitive                # include排序方式
SortJavaStaticImport: Before                  # Java静态导入排序
SortUsingDeclarations: LexicographicNumeric   # using声明排序方式
SpaceAfterCStyleCast: false                   # C风格类型转换后空格
SpaceAfterLogicalNot: false                   # 逻辑非后空格
SpaceAfterTemplateKeyword: true               # template关键字后空格
SpaceAroundPointerQualifiers: Default         # 指针限定符空格
SpaceBeforeAssignmentOperators: true          # 赋值操作符前空格
SpaceBeforeCaseColon: false                   # case冒号前空格
SpaceBeforeCpp11BracedList: false             # C++11大括号列表前空格
SpaceBeforeCtorInitializerColon: true         # 构造函数初始化器冒号前空格
SpaceBeforeInheritanceColon: true             # 继承冒号前空格
SpaceBeforeJsonColon: false                   # JSON冒号前空格
SpaceBeforeParens: ControlStatements          # 括号前空格
SpaceBeforeParensOptions:
  AfterControlStatements: true                # 控制语句后括号前空格
  AfterForeachMacros: true                    # foreach宏后括号前空格
  AfterFunctionDefinitionName: false          # 函数定义名后括号前空格
  AfterFunctionDeclarationName: false         # 函数声明名后括号前空格
  AfterIfMacros:   true                       # if宏后括号前空格
  AfterOverloadedOperator: false              # 重载操作符后括号前空格
  AfterPlacementOperator: true                # 定位操作符后括号前空格
  AfterRequiresInClause: false                # requires子句后括号前空格
  AfterRequiresInExpression: false            # requires表达式后括号前空格
  BeforeNonEmptyParentheses: false            # 非空括号前空格
SpaceBeforeRangeBasedForLoopColon: true       # 范围for循环冒号前空格
SpaceBeforeSquareBrackets: false              # 方括号前空格
SpaceInEmptyBlock: false                      # 空代码块内空格
SpacesBeforeTrailingComments: 1               # 尾部注释前空格数
SpacesInAngles:  Never                        # 尖括号内空格
SpacesInContainerLiterals: true               # 容器字面量内空格
SpacesInLineCommentPrefix:
  Minimum:         1                          # 行注释前最小空格数
  Maximum:         -1                         # 行注释前最大空格数
SpacesInParens:  Never                        # 括号内空格
SpacesInParensOptions:
  ExceptDoubleParentheses: false              # 双括号例外
  InCStyleCasts:   false                      # C风格类型转换括号内空格
  InConditionalStatements: false              # 条件语句括号内空格
  InEmptyParentheses: false                   # 空括号内空格
  Other:           false                      # 其他括号内空格
SpacesInSquareBrackets: false                 # 方括号内空格
Standard:        Auto                         # 标准类型
StatementAttributeLikeMacros:
  - Q_EMIT                                   # 语句属性宏
StatementMacros:
  - Q_UNUSED                                 # 语句宏
  - QT_REQUIRE_VERSION                       # 语句宏
TableGenBreakInsideDAGArg: DontBreak          # TableGen DAG参数换行方式
TabWidth:        4                            # tab宽度
UseTab:          Never                        # 是否使用tab
VerilogBreakBetweenInstancePorts: true        # Verilog端口间换行
WhitespaceSensitiveMacros:
  - BOOST_PP_STRINGIZE                       # 空白敏感宏
  - CF_SWIFT_NAME                            # 空白敏感宏
  - NS_SWIFT_NAME                            # 空白敏感宏
  - PP_STRINGIZE                             # 空白敏感宏
  - STRINGIZE                                # 空白敏感宏

